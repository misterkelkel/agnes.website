---
// ============================================================================
// LazyMediaFrame.astro — lazy-loaded iframe container for streaming media
// ----------------------------------------------------------------------------
// Streams YouTube / Vimeo / Spotify (and any oEmbed iframe) ONLY on user click,
// satisfying the proposal's "lazy-loaded frame wrappers" requirement so heavy
// media payloads never block initial render or mobile load speed.
//
// Props:
//   url       - canonical share/embed URL (YouTube, Vimeo, Spotify, etc.)
//   title     - accessible label for the frame
//   poster    - optional image shown before play (recommended)
//   provider  - 'youtube' | 'vimeo' | 'spotify' | 'generic' (auto-detected)
//   ratio     - CSS aspect-ratio, default 16 / 9
// ============================================================================

interface Props {
  url: string;
  title: string;
  poster?: string;
  provider?: "youtube" | "vimeo" | "spotify" | "generic";
  ratio?: string;
}

const { url, title, poster, ratio = "16 / 9" } = Astro.props;

// --- Map a canonical URL to its embeddable iframe src -----------------------
function toEmbed(u: string): { src: string; provider: string } {
  const yt = u.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([\w-]+)/);
  if (yt) return { src: `https://www.youtube.com/embed/${yt[1]}?autoplay=1`, provider: "youtube" };

  const vimeo = u.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vimeo) return { src: `https://player.vimeo.com/video/${vimeo[1]}?autoplay=1`, provider: "vimeo" };

  const spotify = u.match(/open\.spotify\.com\/(?:episode|track|playlist)\/([\w]+)/);
  if (spotify) return { src: `https://open.spotify.com/embed/${u.split("open.spotify.com/")[1]}?autoplay=1`, provider: "spotify" };

  // Already an embed URL, or unknown → pass through
  return { src: u, provider: "generic" };
}

const { src, provider } = toEmbed(url);
---

<div
  class="iw-media"
  data-iw-media
  data-src={src}
  style={`--iw-media-ratio:${ratio};`}
  role="button"
  tabindex="0"
  aria-label={`Play ${title}`}
>
  {poster && <img class="iw-media__poster" src={poster} alt="" loading="lazy" />}
  <span class="iw-media__play" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="28" height="28"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
  </span>
  <span class="iw-media__provider">{provider}</span>
  <noscript>
    <iframe src={src} title={title} loading="lazy" allow="autoplay; fullscreen"
      referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
  </noscript>
</div>

<script>
  // Hydrate-on-intent: build the iframe only after click/keyboard activation.
  function mount(el: HTMLElement) {
    if (el.dataset.mounted) return;
    const frame = document.createElement("iframe");
    frame.src = el.dataset.src!;
    frame.title = el.getAttribute("aria-label") || "media";
    frame.loading = "lazy";
    frame.allow = "autoplay; fullscreen; encrypted-media";
    frame.referrerPolicy = "strict-origin-when-cross-origin";
    frame.allowFullscreen = true;
    el.dataset.mounted = "1";
    el.innerHTML = "";
    el.appendChild(frame);
    el.classList.add("is-playing");
  }
  document.querySelectorAll<HTMLElement>("[data-iw-media]").forEach((el) => {
    el.addEventListener("click", () => mount(el));
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); mount(el); }
    });
  });
</script>

<style>
  .iw-media {
    position: relative;
    aspect-ratio: var(--iw-media-ratio, 16 / 9);
    background: var(--iw-color-surface-sunk);
    border: 1px solid var(--iw-color-line);
    border-radius: var(--iw-radius-md);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--iw-dur) var(--iw-ease);
  }
  .iw-media:hover { border-color: var(--iw-color-accent); }
  .iw-media__poster {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 0.92;
  }
  .iw-media__play {
    position: relative; z-index: 2;
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--iw-color-bg); color: var(--iw-color-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--iw-shadow-md);
  }
  .iw-media__provider {
    position: absolute; top: 10px; left: 12px; z-index: 2;
    font-family: var(--iw-font-meta); font-size: var(--iw-fs-xs);
    letter-spacing: var(--iw-tracking-eyebrow); text-transform: uppercase;
    color: var(--iw-color-muted);
  }
  .iw-media iframe {
    position: absolute; inset: 0; width: 100%; height: 100%;
    border: 0;
  }
</style>
