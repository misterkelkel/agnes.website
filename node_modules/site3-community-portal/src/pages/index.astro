---
// Site 3 — Home: chronological monthly timeline + multi-edition archive dropdowns.
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const events = (await getCollection("events")).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);
const editions = (await getCollection("editions")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group events by YYYY-MM for the chronological timeline.
const monthKey = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
const monthLabel = (d: Date) =>
  d.toLocaleDateString("en-SG", { month: "long", year: "numeric" });

const groups = new Map<string, typeof events>();
for (const e of events) {
  const k = monthKey(e.data.date);
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(e);
}

const eventSchema = events.map((e) => ({
  "@type": "Event", name: e.data.title,
  startDate: e.data.date.toISOString(),
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: e.data.location ? { "@type": "Place", name: e.data.location } : undefined,
}));

// Editions grouped by track for the multi-edition dropdown.
const tracks: Record<string, string> = {
  "inner-table": "Inner Table",
  "unfinished-conversations": "Unfinished Conversations",
  "threshold": "Threshold",
};
const editionsByTrack = new Map<string, typeof editions>();
for (const ed of editions) {
  if (!editionsByTrack.has(ed.data.track)) editionsByTrack.set(ed.data.track, []);
  editionsByTrack.get(ed.data.track)!.push(ed);
}
---

<Base
  title="innerwork circle — community & events"
  description="Recurring tracks, rolling monthly activations, and archived event galleries."
  schema={eventSchema}
>
  <section class="iw-hero iw-container">
    <p class="iw-eyebrow">Community &amp; Recurring Event Portal</p>
    <h1>The calendar of<br />showing up.</h1>
    <p class="iw-lead">
      Three recurring tracks — Inner Table, Unfinished Conversations, and
      Threshold — meeting month after month. Browse what's next, or open an
      archived edition's photo gallery.
    </p>
  </section>

  <section id="timeline" class="iw-container">
    <h2>Timeline</h2>
    <div class="iw-timeline">
      {[...groups.entries()].map(([k, evs]) => (
        <div>
          <p class="iw-month">{monthLabel(evs[0].data.date)}</p>
          {evs.map((e) => (
            <article class="iw-event">
              <p class="iw-event__date">{e.data.date.toLocaleDateString("en-SG", { day: "numeric", month: "short", year: "numeric" })}</p>
              <h3 class="iw-event__title">{e.data.title}</h3>
              <p>
                <span class="iw-track-tag">{tracks[e.data.track]}</span>
                {e.data.location && <span class="iw-event__date">{e.data.location}</span>}
              </p>
              <p>{e.data.summary}</p>
            </article>
          ))}
        </div>
      ))}
    </div>
  </section>

  <hr class="iw-rule iw-container" />

  <section id="editions" class="iw-container">
    <h2>Edition Archives</h2>
    <p>Pick a track, then choose an edition to view its photo gallery.</p>
    <div class="iw-editions">
      {[...editionsByTrack.entries()].map(([track, eds]) => (
        <div class="iw-edition">
          <h3>{tracks[track]}</h3>
          <select class="iw-edition__select" data-edition-select={track}>
            {eds.map((ed) => (
              <option value={ed.slug}>{ed.data.edition}</option>
            ))}
          </select>
          {eds.map((ed, idx) => (
            <div class="iw-edition__gallery" data-edition-panel={ed.slug}
                 hidden={idx !== 0}>
              {ed.data.note && <p class="iw-event__date">{ed.data.note}</p>}
              <div class="iw-gallery">
                {ed.data.gallery.map((img) => <img src={img} alt={`${ed.data.edition} photo`} loading="lazy" />)}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>
</Base>

<script>
  // Multi-edition dropdown: swap the visible gallery panel per selection.
  document.querySelectorAll<HTMLSelectElement>("[data-edition-select]").forEach((sel) => {
    const sync = () => {
      const track = sel.dataset.editionSelect!;
      const current = sel.value;
      document
        .querySelectorAll<HTMLElement>(`[data-edition-panel]`)
        .forEach((panel) => {
          const slug = panel.dataset.editionPanel!;
          // Only toggle panels belonging to this track's options.
          const belongs = [...sel.options].some((o) => o.value === slug);
          panel.hidden = !(belongs && slug === current);
        });
    };
    sel.addEventListener("change", sync);
    sync();
  });
</script>

<style>
  .iw-hero { padding-block: var(--iw-space-6); }
  .iw-lead { font-size: var(--iw-fs-md); max-width: var(--iw-maxw-narrow);
    color: var(--iw-color-ink-soft); }
</style>
