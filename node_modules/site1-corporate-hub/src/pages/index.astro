---
// Site 1 — Home: program rows + testimonials + intake form + lazy media.
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ContactForm from "@components/ContactForm.astro";
import MediaFrame from "@components/MediaFrame.astro";

const programs = (await getCollection("programs")).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection("testimonials")).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);

const formFields = [
  { name: "name", label: "Name", required: true },
  { name: "email", label: "Email", type: "email", required: true },
  { name: "company", label: "Company", required: false },
  { name: "program", label: "Program of Interest", type: "select",
    options: programs.map((p) => p.data.title), required: true },
  { name: "message", label: "Message", type: "textarea", required: false },
];

const programSchema = programs.map((p) => ({
  "@type": "Course", name: p.data.title, description: p.data.summary,
  provider: { "@type": "Organization", name: "innerwork circle" },
  educationalCredentialAwarded: p.data.duration,
}));
---

<Base
  title="innerwork circle — Programs & Intensives"
  description="B2B/B2C intensives, executive leadership, team excellence, and bespoke consulting."
  schema={programSchema}
>
  <section class="iw-hero">
    <div class="iw-container">
      <p class="iw-eyebrow">Corporate &amp; Program Hub</p>
      <h1>Programs that move people<br />and organizations.</h1>
      <p class="iw-lead">
        Three-day intensives, executive leadership development, team excellence
        paths, and bespoke commercial consulting — built for measurable change.
      </p>
    </div>
  </section>

  <section id="programs" class="iw-container">
    <h2>Programs</h2>
    {programs.map((p) => (
      <article class="iw-program-row">
        <div class="iw-program-row__media">
          {p.data.heroImage
            ? <img src={p.data.heroImage} alt={p.data.title} loading="lazy" />
            : null}
        </div>
        <div>
          <p class="iw-program-row__meta">{p.data.eyebrow ?? p.data.duration} · {p.data.audience.toUpperCase()}</p>
          <h3>{p.data.title}</h3>
          <p>{p.data.summary}</p>
          {p.data.outcomes.length > 0 && (
            <ul>
              {p.data.outcomes.map((o) => <li>{o}</li>)}
            </ul>
          )}
          {p.data.ctaUrl && <a href={p.data.ctaUrl}>{p.data.ctaLabel} →</a>}
        </div>
      </article>
    ))}
  </section>

  <hr class="iw-rule iw-container" />

  <section id="testimonials" class="iw-container">
    <h2>Voices</h2>
    {testimonials.map((t) => (
      <blockquote class="iw-quote">
        “{t.data.quote}”
        <footer class="iw-quote__by">{t.data.name} — {t.data.role}</footer>
      </blockquote>
    ))}
  </section>

  <hr class="iw-rule iw-container" />

  <section id="enquire" class="iw-container">
    <h2>Enquire</h2>
    <p>Tell us which program you’re exploring — we’ll be in touch shortly.</p>
    <ContactForm name="site1-intake" fields={formFields} ctaLabel="Send Enquiry" />
  </section>

  <section class="iw-container" style="margin-top: var(--iw-space-5);">
    <h2>Featured Conversation</h2>
    <MediaFrame
      url="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
      title="innerwork circle introductory film"
      ratio="16 / 9"
    />
  </section>
</Base>

<style>
  .iw-hero { padding-block: var(--iw-space-6); }
  .iw-lead { font-size: var(--iw-fs-md); max-width: var(--iw-maxw-narrow);
    color: var(--iw-color-ink-soft); }
</style>
